#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: $(basename "$0") [-u|--user USERNAME]"
    echo
    echo "Clone all FM repositories from adhocmarkets into the parent directory,"
    echo "setting up fork as origin and org repo as upstream."
    echo
    echo "The script operates in the parent directory of wherever fm-development"
    echo "is cloned. For example, if cloned to ~/dev/fm-development, repos are"
    echo "cloned into ~/dev/."
    echo
    echo "Options:"
    echo "  -u, --user USERNAME   GitHub username for fork (default: JanStureNielsen)"
    echo "  -h, --help            Show this help message"
    exit 0
}

USER="JanStureNielsen"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--user) USER="$2"; shift 2 ;;
        -h|--help) usage ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$DIR"

# repo_name  local_dir  has_upstream
REPOS=(
    "fm-data        fm-server              yes"
    "fm-ui          fm-ui                  yes"
    "fm-robots      fm-robots              yes"
    "fm-robots-container fm-robots-container no"
    "fm-sdk         fm-sdk                 yes"
    "fm-administration fm-administration   yes"
)

for entry in "${REPOS[@]}"; do
    read -r repo local_dir has_upstream <<< "$entry"

    if [[ -d "$DIR/$local_dir" ]]; then
        echo "SKIP $local_dir (already exists)"
        continue
    fi

    if [[ "$has_upstream" == "yes" ]]; then
        echo "CLONE adhocmarkets/$repo -> $local_dir"
        git clone "git@github.com:adhocmarkets/$repo.git" "$local_dir"
        cd "$local_dir"
        git remote rename origin upstream
        git remote add origin "git@github.com:$USER/$repo.git"
        git fetch --all
        cd "$DIR"
    elif [[ "$has_upstream" == "org" ]]; then
        echo "CLONE adhocmarkets/$repo -> $local_dir (org only)"
        git clone "git@github.com:adhocmarkets/$repo.git" "$local_dir"
    else
        echo "CLONE $USER/$repo -> $local_dir (no upstream)"
        git clone "git@github.com:$USER/$repo.git" "$local_dir"
    fi
done

echo "Done."
